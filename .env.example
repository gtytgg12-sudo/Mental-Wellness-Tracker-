# --- Core ---
NODE_ENV=development

# --- Database ---
# SQLite (default) — file-based, no setup
DATABASE_URL="file:./dev.db"
# For PostgreSQL, replace with:
# DATABASE_URL="postgresql://user:password@localhost:5432/wellness?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-32-byte-random-secret-min-please-rotate-in-prod"
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000

# --- AI Provider (optional) ---
# Leave empty to use the built-in heuristic reflection engine
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o-mini"

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
